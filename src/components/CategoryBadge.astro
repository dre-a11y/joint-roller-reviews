---
interface Props {
  badge: string;
}
const { badge } = Astro.props;

const colors: Record<string, { bg: string; color: string }> = {
  'Best for High Volume':          { bg: '#dbeafe', color: '#1e40af' },
  'Best for Quality/Consistency':  { bg: '#dcfce7', color: '#166534' },
  'Best Value':                    { bg: '#fef9c3', color: '#854d0e' },
  'Most Format-Flexible':          { bg: '#f3e8ff', color: '#6b21a8' },
  'Best Entry-Level':              { bg: '#ffedd5', color: '#9a3412' },
  'Best for Craft/Premium Brands': { bg: '#fce7f3', color: '#9d174d' },
};

const style = colors[badge] ?? { bg: '#f1f5f9', color: '#475569' };
---

<span class="badge" style={`background:${style.bg};color:${style.color}`}>{badge}</span>

<style>
  .badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
</style>
