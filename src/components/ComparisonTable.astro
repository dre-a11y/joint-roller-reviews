---
import CategoryBadge from './CategoryBadge.astro';

interface Machine {
  slug: string;
  title: string;
  priceLabel: string;
  throughputPerHour: number;
  badge?: string;
  overallScore?: number;
  rank?: number;
}

interface Props {
  machines: Machine[];
}

const { machines } = Astro.props;
const sorted = [...machines].sort((a, b) => (a.rank ?? 99) - (b.rank ?? 99));
---

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Machine</th>
        <th>Price</th>
        <th>Throughput</th>
        <th>Category</th>
        <th>Score</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map(m => (
        <tr>
          <td class="rank">{m.rank ?? '—'}</td>
          <td class="name"><a href={`/reviews/${m.slug}`}>{m.title}</a></td>
          <td class="nowrap">{m.priceLabel}</td>
          <td class="nowrap">~{m.throughputPerHour.toLocaleString()}/hr</td>
          <td>{m.badge ? <CategoryBadge badge={m.badge} /> : <span class="dash">—</span>}</td>
          <td class="score">{m.overallScore != null ? m.overallScore.toFixed(1) : '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap {
    overflow-x: auto;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  thead { background: #f8fafc; border-bottom: 2px solid #e5e7eb; }

  th {
    padding: 0.7rem 1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6b7280;
    white-space: nowrap;
  }

  td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #fafafa; }

  .rank  { font-weight: 700; color: #94a3b8; width: 40px; }
  .name  a { color: #0f172a; font-weight: 500; }
  .name  a:hover { color: #166534; }
  .score { font-weight: 700; color: #166534; font-variant-numeric: tabular-nums; }
  .nowrap { white-space: nowrap; }
  .dash  { color: #d1d5db; }
</style>
