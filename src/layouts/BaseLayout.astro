---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const defaultDesc = "Independent reviews of commercial pre-roll machines for dispensary operators and c*nn*bis brand owners.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? defaultDesc} />
    <title>{title} | Pre-Roller Reviews</title>
  </head>
  <body>
    <header>
      <nav class="nav-inner">
        <a href="/" class="site-name">Pre-Roller Reviews</a>
        <div class="nav-links">
          <a href="/">Rankings</a>
          <a href="/how-to-choose-a-pre-roll-machine">Buyer's Guide</a>
          <a href="/methodology">Methodology</a>
        </div>
      </nav>
    </header>

    <slot />

    <footer>
      <div class="footer-inner">
        <p>Independent editorial. No commercial relationships with any manufacturer.</p>
        <p><a href="/methodology">Methodology</a> · Updated monthly · <a href="/">Rankings</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #111827;
    background: #fff;
  }

  a { color: #166534; text-decoration: none; }
  a:hover { text-decoration: underline; }

  h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; color: #0f172a; }
  h2 { font-size: 1.4rem; font-weight: 700; color: #0f172a; }
  h3 { font-size: 1.1rem; font-weight: 600; color: #0f172a; }
  h4 { font-size: 0.95rem; font-weight: 600; color: #0f172a; }

  p { margin-bottom: 1rem; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>

<style>
  header {
    background: #0f172a;
    padding: 0 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .site-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff !important;
    letter-spacing: -0.01em;
    text-decoration: none;
  }

  .nav-links { display: flex; gap: 1.5rem; }

  .nav-links a {
    color: #94a3b8;
    font-size: 0.88rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover { color: #fff; text-decoration: none; }

  footer {
    background: #f8fafc;
    border-top: 1px solid #e5e7eb;
    padding: 2rem 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    font-size: 0.83rem;
    color: #6b7280;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-inner a { color: #6b7280; }
  .footer-inner a:hover { color: #166534; }
</style>
