    overflow: hidden;
  }

  .rubric-table thead {
    background: #f8fafc;
    border-bottom: 2px solid #e5e7eb;
  }

  .rubric-table th {
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    font-size: 0.88rem;
  }

  .rubric-table td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: #374151;
    font-size: 0.88rem;
  }

  .rubric-table tr:last-child td {
    border-bottom: none;
  }

  .cta {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 2rem;
    margin-top: 3rem;
  }

  .cta h2 {
    margin-bottom: 0.5rem;
  }

  .cta p {
    color: #6b7280;
    margin-bottom: 0;
  }

  .cta a {
    font-weight: 600;
  }
</style>